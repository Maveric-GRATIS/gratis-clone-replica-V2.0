# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Payment Integration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Stripe Price IDs (from Stripe Dashboard > Products)
VITE_STRIPE_PRICE_INSIDER_MONTHLY=price_xxx
VITE_STRIPE_PRICE_INSIDER_YEARLY=price_xxx
VITE_STRIPE_PRICE_CORE_MONTHLY=price_xxx
VITE_STRIPE_PRICE_CORE_YEARLY=price_xxx
VITE_STRIPE_PRICE_FOUNDER_MONTHLY=price_xxx
VITE_STRIPE_PRICE_FOUNDER_YEARLY=price_xxx

# Stripe Customer Portal URL
VITE_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/xxx

# Mux Video Platform
VITE_MUX_ENVIRONMENT_KEY=your_mux_key_here

# Optional: Map Integration
VITE_MAPBOX_PUBLIC_TOKEN=your_mapbox_token_here
