rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isMarketing() {
      return isAuthenticated() && (getUserRole() == 'marketing' || isAdmin());
    }

    // User roles collection
    match /user_roles/{roleId} {
      // Users can read their own roles, admins can read all
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());

      // Only admins can create/update/delete roles
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own data, admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // TEMPORARY: Allow specific user to set admin role
      allow create, update: if isAuthenticated()
                            && request.auth.uid == 'qvPtEb2ZjWc8HHRMU28IToj2KWu2';

      // Users can create their own profile on signup
      allow create: if isAuthenticated() && isOwner(userId)
                    && request.resource.data.role == 'customer';

      // Users can update their own data (except role), admins can update anything
      allow update: if isOwner(userId)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      // Everyone can read products
      allow read: if true;

      // Only admins can create/update/delete products
      allow create, update, delete: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Users can read their own orders, admins can read all
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Users can create their own orders
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;

      // Only admins can update orders (for status changes)
      allow update: if isAdmin();

      // No one can delete orders
      allow delete: if false;
    }

    // Reviews collection
    match /reviews/{reviewId} {
      // Everyone can read reviews
      allow read: if true;

      // Authenticated users can create reviews for their own user ID
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;

      // Users can update/delete their own reviews, admins can do anything
      allow update, delete: if isAuthenticated()
                            && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Audit logs - only admins can read, system writes
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // Distribution locations
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isMarketing();
    }

    // Wishlist
    match /wishlist/{userId}/{items=**} {
      allow read, write: if isOwner(userId);
    }

    // Cart items (if stored in Firestore)
    match /carts/{userId}/{items=**} {
      allow read, write: if isOwner(userId);
    }

    // Job Applications
    match /jobApplications/{applicationId} {
      // Anyone can submit an application
      allow create: if true
                    && request.resource.data.keys().hasAll(['position', 'name', 'email', 'phone', 'city', 'coverLetter', 'startDate', 'resumeUrl', 'status'])
                    && request.resource.data.status == 'pending';

      // Only admins can read, update, or delete applications
      allow read, update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      // Users can read their own notifications, admins can read all
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Only system (Cloud Functions) and admins can create notifications
      allow create: if isAdmin();

      // Users can update their own notifications (mark as read), admins can update all
      allow update: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());

      // Users can delete their own notifications, admins can delete all
      allow delete: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
