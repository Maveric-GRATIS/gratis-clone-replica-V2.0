rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isMarketing() {
      return isAuthenticated() && (getUserRole() == 'marketing' || isAdmin());
    }

    // User roles collection
    match /user_roles/{roleId} {
      // Users can read their own roles, admins can read all
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());

      // Only admins can create/update/delete roles
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own data, admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own profile on signup (role must be 'customer')
      allow create: if isAuthenticated() && isOwner(userId)
                    && request.resource.data.role == 'customer';

      // Users can update their own data (except role), admins can update anything
      allow update: if isOwner(userId)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Profiles collection (user profile data separate from auth)
    match /profiles/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can create and update their own profile
      allow create, update: if isAuthenticated() && isOwner(userId);

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      // Everyone can read products
      allow read: if true;

      // Only admins can create/update/delete products
      allow create, update, delete: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Users can read their own orders, admins can read all
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Users can create their own orders
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;

      // Only admins can update orders (for status changes)
      allow update: if isAdmin();

      // No one can delete orders
      allow delete: if false;
    }

    // Reviews collection
    match /reviews/{reviewId} {
      // Everyone can read reviews
      allow read: if true;

      // Authenticated users can create reviews for their own user ID
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;

      // Users can update/delete their own reviews, admins can do anything
      allow update, delete: if isAuthenticated()
                            && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Audit logs - only admins can read, system writes
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // Distribution locations
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isMarketing();
    }

    // Blog posts
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isMarketing();
    }

    // Videos
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Wishlist
    match /wishlist/{userId}/{items=**} {
      allow read, write: if isOwner(userId);
    }

    // Cart items (if stored in Firestore)
    match /carts/{userId}/{items=**} {
      allow read, write: if isOwner(userId);
    }

    // Job Applications — only written by Cloud Functions (not direct client writes)
    match /jobApplications/{applicationId} {
      // Authenticated users can submit — but NOT direct client writes; use allow create: if false
      // to force all writes through validated Cloud Functions
      allow create: if false; // Cloud Functions only via Admin SDK

      // Only admins can read, update, or delete applications
      allow read, update, delete: if isAdmin();
    }

    // Partners collection
    match /partners/{partnerId} {
      // Anyone can read approved partners
      allow read: if resource.data.status == 'approved' || isAdmin();

      // Only admins can create, update, or delete partners
      allow create, update, delete: if isAdmin();
    }

    // Partner Applications — only written by Cloud Functions
    match /partnerApplications/{applicationId} {
      allow create: if false; // Cloud Functions only via Admin SDK

      // Only admins can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    // NGO Applications — only written by Cloud Functions
    match /ngoApplications/{applicationId} {
      allow create: if false; // Cloud Functions only via Admin SDK

      // Only admins can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      // Users can read their own notifications, admins can read all
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Only system (Cloud Functions) and admins can create notifications
      allow create: if isAdmin();

      // Users can only mark their own notifications as read (no other field changes)
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
                    && request.resource.data.read == true
                    || isAdmin();

      // Users can delete their own notifications, admins can delete all
      allow delete: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Contact Messages — written by Cloud Functions only
    match /contactMessages/{msgId} {
      allow read:   if isAdmin();
      allow create: if false; // Cloud Functions only via Admin SDK
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Partner Inquiries — written by Cloud Functions only
    match /partnerInquiries/{id} {
      allow read:   if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Volunteer Applications — written by Cloud Functions only
    match /volunteerApplications/{id} {
      allow read:   if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rate Limits — Admin SDK only, never direct client access
    match /rateLimits/{key} {
      allow read, write: if false;
    }
  } // end match /databases/{database}/documents
} // end service cloud.firestore