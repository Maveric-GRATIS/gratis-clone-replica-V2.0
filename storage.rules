rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidImageUpload() {
      return request.resource.size < 5 * 1024 * 1024 // 5MB limit
             && request.resource.contentType.matches('image/.*');
    }

    // Product images - admins can write, everyone can read
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    // User profile images
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidImageUpload();
    }

    // User avatars (profile photos)
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidImageUpload();
    }

    // Event images
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    // Job application resumes - anyone can upload, only admins can read
    match /applications/{fileName} {
      allow create: if request.resource.size < 5 * 1024 * 1024 // 5MB limit
                    && (request.resource.contentType.matches('application/pdf')
                        || request.resource.contentType.matches('application/msword')
                        || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document'));
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
